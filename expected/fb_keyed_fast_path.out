DO $$
BEGIN
	IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_flashback') THEN
		EXECUTE 'DROP EXTENSION pg_flashback CASCADE';
	END IF;
END;
$$;
CREATE EXTENSION pg_flashback;
SET pg_flashback.show_progress = off;
SET pg_flashback.runtime_retention = 0;
SET pg_flashback.recovered_wal_retention = 0;
SET pg_flashback.meta_retention = 0;
DO $$
BEGIN
	EXECUTE format('SET pg_flashback.archive_dir = %L', current_setting('data_directory') || '/pg_wal');
END;
$$;
DROP TABLE IF EXISTS fb_keyed_fast_path_mark;
NOTICE:  table "fb_keyed_fast_path_mark" does not exist, skipping
DROP TABLE IF EXISTS fb_keyed_fast_path_target;
NOTICE:  table "fb_keyed_fast_path_target" does not exist, skipping
CREATE TABLE fb_keyed_fast_path_target (
	id bigint PRIMARY KEY,
	payload text NOT NULL,
	amount integer NOT NULL
);
CHECKPOINT;
INSERT INTO fb_keyed_fast_path_target VALUES
	(1, 'one', 10),
	(2, 'two', 20),
	(3, 'three', 30),
	(4, 'four', 40),
	(5, 'five', 50),
	(6, 'six', 60);
CREATE TABLE fb_keyed_fast_path_mark (
	target_ts timestamptz NOT NULL
);
INSERT INTO fb_keyed_fast_path_mark VALUES (clock_timestamp());
UPDATE fb_keyed_fast_path_target
SET payload = 'two-new', amount = 200
WHERE id = 2;
DELETE FROM fb_keyed_fast_path_target
WHERE id = 4;
INSERT INTO fb_keyed_fast_path_target VALUES
	(7, 'seven', 70);
EXPLAIN (VERBOSE, COSTS OFF)
SELECT *
FROM pg_flashback(
	NULL::public.fb_keyed_fast_path_target,
	(SELECT target_ts::text FROM fb_keyed_fast_path_mark)
)
WHERE id = 2;
                                             QUERY PLAN                                             
----------------------------------------------------------------------------------------------------
 Custom Scan (FbApplyScan)
   Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
   Flashback Relation: public.fb_keyed_fast_path_target
   Fast Path: key_eq
   Fast Path Key: id
   InitPlan 1
     ->  Seq Scan on public.fb_keyed_fast_path_mark
           Output: (fb_keyed_fast_path_mark.target_ts)::text
   ->  Custom Scan (FbReverseSourceScan)
         Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
         ->  Custom Scan (FbReplayFinalScan)
               Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
               ->  Custom Scan (FbReplayWarmScan)
                     Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
                     ->  Custom Scan (FbReplayDiscoverScan)
                           Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
                           ->  Custom Scan (FbWalIndexScan)
                                 Output: pg_flashback.id, pg_flashback.payload, pg_flashback.amount
(18 rows)

SELECT *
FROM pg_flashback(
	NULL::public.fb_keyed_fast_path_target,
	(SELECT target_ts::text FROM fb_keyed_fast_path_mark)
)
WHERE id = 2;
 id | payload | amount 
----+---------+--------
  2 | two     |     20
(1 row)

