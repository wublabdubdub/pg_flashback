	15000,
	16000,
	17000,
	18000,
	19000,
	20000,
	21000,
	22000,
	23000
]::bigint[]);
 fb_progress_debug_set_clock 
-----------------------------
 
(1 row)

SELECT *
FROM pg_flashback(
	NULL::public.fb_progress_target,
	(SELECT target_ts::text FROM fb_progress_mark)
)
ORDER BY id;
