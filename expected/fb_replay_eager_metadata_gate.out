RETURNS text
AS '$libdir/pg_flashback', 'fb_replay_eager_metadata_gate_contract_debug'
LANGUAGE C STRICT;
SELECT fb_replay_eager_metadata_gate_contract_debug();
                            fb_replay_eager_metadata_gate_contract_debug                             
-----------------------------------------------------------------------------------------------------
 lookahead_eager_precompute=false locator_payload_eager_precompute=false plain_eager_precompute=true
