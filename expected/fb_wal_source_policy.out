DO $$
BEGIN
	IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_flashback') THEN
		EXECUTE 'DROP EXTENSION pg_flashback CASCADE';
	END IF;
END;
$$;
CREATE EXTENSION pg_flashback;
CREATE OR REPLACE FUNCTION fb_archive_resolve_debug()
RETURNS text
AS '$libdir/pg_flashback', 'fb_archive_resolve_debug'
LANGUAGE C
STRICT;
SELECT current_setting('archive_command') AS orig_archive_command,
	   current_setting('archive_library') AS orig_archive_library
\gset
COPY (SELECT '') TO PROGRAM 'rm -rf /tmp/fb_core_archive /tmp/fb_explicit_archive /tmp/fb_pb_catalog && mkdir -p /tmp/fb_core_archive /tmp/fb_explicit_archive /tmp/fb_pb_catalog/wal/node';
ALTER SYSTEM RESET archive_library;
ALTER SYSTEM SET archive_command = 'cp %p /tmp/fb_core_archive/%f';
SELECT pg_reload_conf();
 pg_reload_conf 
----------------
 t
(1 row)

\c contrib_regression
LOAD 'pg_flashback';
SET pg_flashback.archive_dest = '/tmp/fb_explicit_archive';
SELECT fb_archive_resolve_debug() =
	   'mode=archive_dest setting=pg_flashback.archive_dest path=/tmp/fb_explicit_archive';
 ?column? 
----------
 t
(1 row)

RESET pg_flashback.archive_dest;
SELECT fb_archive_resolve_debug() =
	   'mode=archive_command setting=archive_command path=/tmp/fb_core_archive';
 ?column? 
----------
 t
(1 row)

ALTER SYSTEM SET archive_command = '"/usr/bin/pg_probackup" archive-push -B "/tmp/fb_pb_catalog" --instance=node --wal-file-name=%f';
SELECT pg_reload_conf();
 pg_reload_conf 
----------------
 t
(1 row)

\c contrib_regression
LOAD 'pg_flashback';
SELECT fb_archive_resolve_debug() =
	   'mode=archive_command setting=archive_command path=/tmp/fb_pb_catalog/wal/node';
 ?column? 
----------
 t
(1 row)

ALTER SYSTEM RESET archive_command;
ALTER SYSTEM SET archive_library = 'dummy_archive_library';
SELECT pg_reload_conf();
 pg_reload_conf 
----------------
 t
(1 row)

\c contrib_regression
LOAD 'pg_flashback';
SELECT fb_archive_resolve_debug();
ERROR:  could not determine WAL archive directory automatically
DETAIL:  PostgreSQL archive_library is set; pg_flashback does not infer a local archive directory from archive_library.
HINT:  Set pg_flashback.archive_dest explicitly.
ALTER SYSTEM RESET archive_library;
ALTER SYSTEM SET archive_command = :'orig_archive_command';
SELECT pg_reload_conf();
 pg_reload_conf 
----------------
 t
(1 row)

\c contrib_regression
LOAD 'pg_flashback';
