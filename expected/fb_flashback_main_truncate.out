DO $$
BEGIN
	IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_flashback') THEN
		EXECUTE 'DROP EXTENSION pg_flashback CASCADE';
	END IF;
END;
$$;
CREATE EXTENSION pg_flashback;
SET pg_flashback.show_progress = off;
DO $$
BEGIN
	EXECUTE format('SET pg_flashback.archive_dir = %L',
				   current_setting('data_directory') || '/pg_wal');
END;
$$;
CREATE TABLE fb_flashback_main_truncate_target (
	id integer PRIMARY KEY,
	payload text NOT NULL
);
CREATE TABLE fb_flashback_main_truncate_mark (
	target_ts timestamptz NOT NULL
);
CREATE TABLE fb_flashback_main_truncate_size (
	label text PRIMARY KEY,
	pages bigint NOT NULL
);
CREATE TABLE fb_flashback_main_truncate_truth (
	id integer PRIMARY KEY,
	payload text NOT NULL
);
CREATE TABLE fb_flashback_main_truncate_result (
	id integer PRIMARY KEY,
	payload text NOT NULL
);
INSERT INTO fb_flashback_main_truncate_target
SELECT g,
	   repeat(md5(g::text), 32)
FROM generate_series(1, 12000) AS g;
INSERT INTO fb_flashback_main_truncate_mark
VALUES (clock_timestamp());
INSERT INTO fb_flashback_main_truncate_truth
SELECT *
FROM fb_flashback_main_truncate_target;
INSERT INTO fb_flashback_main_truncate_size
SELECT 'before_vacuum',
	   pg_relation_size('fb_flashback_main_truncate_target'::regclass) / 8192;
DELETE FROM fb_flashback_main_truncate_target
WHERE id > 4000;
VACUUM fb_flashback_main_truncate_target;
INSERT INTO fb_flashback_main_truncate_size
SELECT 'after_vacuum',
	   pg_relation_size('fb_flashback_main_truncate_target'::regclass) / 8192;
SELECT (SELECT pages
		FROM fb_flashback_main_truncate_size
		WHERE label = 'before_vacuum') >
	   (SELECT pages
		FROM fb_flashback_main_truncate_size
		WHERE label = 'after_vacuum') AS main_shrank;
 main_shrank 
-------------
 t
(1 row)

INSERT INTO fb_flashback_main_truncate_result
SELECT *
FROM pg_flashback(
	NULL::public.fb_flashback_main_truncate_target,
	(SELECT target_ts::text
	 FROM fb_flashback_main_truncate_mark)
);
SELECT (SELECT count(*) FROM fb_flashback_main_truncate_truth) AS truth_count,
	   (SELECT count(*) FROM fb_flashback_main_truncate_result) AS result_count,
	   (SELECT count(*)
		FROM (
			(SELECT * FROM fb_flashback_main_truncate_truth
			 EXCEPT ALL
			 SELECT * FROM fb_flashback_main_truncate_result)
			UNION ALL
			(SELECT * FROM fb_flashback_main_truncate_result
			 EXCEPT ALL
			 SELECT * FROM fb_flashback_main_truncate_truth)
		) AS diff_rows) AS diff_count;
 truth_count | result_count | diff_count 
-------------+--------------+------------
