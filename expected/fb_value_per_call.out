DO $$
BEGIN
	IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_flashback') THEN
		EXECUTE 'DROP EXTENSION pg_flashback CASCADE';
	END IF;
END;
$$;
CREATE EXTENSION pg_flashback;
DO $$
BEGIN
	EXECUTE format('SET pg_flashback.archive_dir = %L', current_setting('data_directory') || '/pg_wal');
END;
$$;
DO $$
BEGIN
	IF to_regprocedure('fb_srf_mode_debug(anyelement,text)') IS NOT NULL THEN
		EXECUTE 'DROP FUNCTION fb_srf_mode_debug(anyelement, text)';
	END IF;
END;
$$;
CREATE FUNCTION fb_srf_mode_debug(anyelement, text)
RETURNS SETOF text
AS '$libdir/pg_flashback', 'fb_srf_mode_debug'
LANGUAGE C;
SET pg_flashback.show_progress = off;
CREATE TABLE fb_value_per_call_target (
	id integer PRIMARY KEY,
	payload text NOT NULL
);
CHECKPOINT;
INSERT INTO fb_value_per_call_target
SELECT g,
	   (
		   SELECT string_agg(md5((g * 1000 + s)::text), '' ORDER BY s)
		   FROM generate_series(1, 32) AS s
	   )
FROM generate_series(1, 10000) AS g;
CREATE TABLE fb_value_per_call_mark (
	target_ts timestamptz NOT NULL
);
INSERT INTO fb_value_per_call_mark VALUES (clock_timestamp());
UPDATE fb_value_per_call_target
SET payload = repeat('z', 512)
WHERE (id % 2) = 0;
SELECT *
FROM fb_srf_mode_debug(
	NULL::public.fb_value_per_call_target,
	(SELECT target_ts::text FROM fb_value_per_call_mark)
);
   fb_srf_mode_debug   
-----------------------
 chosen=value_per_call
(1 row)

CREATE TABLE fb_value_per_call_probe (
	result_count bigint NOT NULL,
	temp_bytes_delta bigint NOT NULL
);
DO $$
DECLARE
	before_bytes bigint;
	after_bytes bigint;
	result_count bigint;
BEGIN
	PERFORM pg_stat_force_next_flush();
	PERFORM pg_stat_clear_snapshot();

	SELECT temp_bytes
	INTO before_bytes
	FROM pg_stat_database
	WHERE datname = current_database();

	PERFORM set_config('work_mem', '64kB', true);

	SELECT count(*)
	INTO result_count
	FROM pg_flashback(
		NULL::public.fb_value_per_call_target,
		(SELECT target_ts::text FROM fb_value_per_call_mark)
	);

	PERFORM pg_stat_force_next_flush();
	PERFORM pg_stat_clear_snapshot();

	SELECT temp_bytes
	INTO after_bytes
	FROM pg_stat_database
	WHERE datname = current_database();

	INSERT INTO fb_value_per_call_probe
	VALUES (result_count, GREATEST(after_bytes - before_bytes, 0));
END;
$$;
SELECT result_count = 10000 AS count_ok,
	   temp_bytes_delta = 0 AS no_temp_spill
FROM fb_value_per_call_probe;
 count_ok | no_temp_spill 
----------+---------------
 t        | t
(1 row)

