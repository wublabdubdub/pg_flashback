SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_flashback;
RESET client_min_messages;
SET pg_flashback.show_progress = off;
CREATE FUNCTION fb_wal_parallel_missing_continuity_contract_debug()
RETURNS text
AS '$libdir/pg_flashback', 'fb_wal_parallel_missing_continuity_contract_debug'
LANGUAGE C STRICT;
SELECT fb_wal_parallel_missing_continuity_contract_debug();
             fb_wal_parallel_missing_continuity_contract_debug              
----------------------------------------------------------------------------
 parallel_missing_continuity=true merged_count=1 kept_first_record_index=13
(1 row)

DROP FUNCTION fb_wal_parallel_missing_continuity_contract_debug();
