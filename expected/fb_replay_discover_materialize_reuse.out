SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_flashback;
RESET client_min_messages;
SET pg_flashback.show_progress = off;
CREATE FUNCTION fb_replay_discover_materialize_reuse_contract_debug(regclass, timestamptz)
RETURNS text
AS '$libdir/pg_flashback', 'fb_replay_discover_materialize_reuse_contract_debug'
LANGUAGE C STRICT;
CREATE TABLE fb_replay_discover_materialize_reuse_t(
    id int PRIMARY KEY,
    payload text
);
SELECT clock_timestamp() AS target_ts \gset
INSERT INTO fb_replay_discover_materialize_reuse_t
VALUES
    (1, repeat('a', 8000)),
    (2, repeat('b', 8000));
UPDATE fb_replay_discover_materialize_reuse_t
SET payload = repeat('c', 8000)
WHERE id = 2;
SELECT pg_switch_wal() AS switched_lsn \gset
SELECT fb_replay_discover_materialize_reuse_contract_debug(
    'fb_replay_discover_materialize_reuse_t'::regclass,
    :'target_ts'::timestamptz
);
  fb_replay_discover_materialize_reuse_contract_debug  
-------------------------------------------------------
 record_reads=1 record_index=0 record_kind=heap_insert
(1 row)

DROP TABLE fb_replay_discover_materialize_reuse_t;
