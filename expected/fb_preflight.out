DO $$
BEGIN
	IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_flashback') THEN
		EXECUTE 'DROP EXTENSION pg_flashback CASCADE';
	END IF;
END;
$$;
CREATE EXTENSION pg_flashback;
SET pg_flashback.show_progress = off;
DO $$
BEGIN
	EXECUTE format('SET pg_flashback.archive_dir = %L', current_setting('data_directory') || '/pg_wal');
END;
$$;
CREATE TABLE fb_preflight_target (
	id integer PRIMARY KEY,
	payload text
);
CHECKPOINT;
INSERT INTO fb_preflight_target VALUES (1, 'baseline');
CREATE TABLE fb_preflight_mark (
	target_ts timestamptz NOT NULL
);
INSERT INTO fb_preflight_mark VALUES (clock_timestamp());
DO $$
DECLARE
	i integer;
BEGIN
	FOR i IN 1..5000 LOOP
		UPDATE fb_preflight_target
		SET payload = format('after-%s', i)
		WHERE id = 1;
	END LOOP;
END;
$$;
SET pg_flashback.memory_limit = 512;
SET pg_flashback.spill_mode = 'auto';
SELECT count(*)
FROM pg_flashback(
	NULL::public.fb_preflight_target,
	(SELECT target_ts::text FROM fb_preflight_mark)
);
ERROR:  estimated flashback working set exceeds pg_flashback.memory_limit
DETAIL:  estimated=4045310 bytes limit=524288 bytes (512 KB) mode=auto phase=preflight
HINT:  Increase pg_flashback.memory_limit, or set pg_flashback.spill_mode = 'disk' to allow spill.
SET pg_flashback.spill_mode = 'memory';
SELECT count(*)
FROM pg_flashback(
	NULL::public.fb_preflight_target,
	(SELECT target_ts::text FROM fb_preflight_mark)
);
ERROR:  flashback is configured to run in memory-only mode, but the estimated working set exceeds pg_flashback.memory_limit
DETAIL:  estimated=4045310 bytes limit=524288 bytes (512 KB) mode=memory phase=preflight
HINT:  Increase pg_flashback.memory_limit, or set pg_flashback.spill_mode = 'disk'.
SET pg_flashback.spill_mode = 'disk';
SET client_min_messages = warning;
WITH flashback AS (
	SELECT *
	FROM pg_flashback(
		NULL::public.fb_preflight_target,
		(SELECT target_ts::text FROM fb_preflight_mark)
	)
)
SELECT count(*) AS result_count,
	   min(id) AS min_id,
	   max(id) AS max_id,
	   max(payload) = 'baseline' AS restored_baseline
FROM flashback;
 result_count | min_id | max_id | restored_baseline 
--------------+--------+--------+-------------------
            1 |      1 |      1 | t
(1 row)

RESET client_min_messages;
