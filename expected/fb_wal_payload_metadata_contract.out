SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_flashback;
RESET client_min_messages;
SET pg_flashback.show_progress = off;
CREATE FUNCTION fb_wal_payload_metadata_contract_debug()
RETURNS text
AS '$libdir/pg_flashback', 'fb_wal_payload_metadata_contract_debug'
LANGUAGE C STRICT;
SELECT fb_wal_payload_metadata_contract_debug();
                                       fb_wal_payload_metadata_contract_debug                                       
--------------------------------------------------------------------------------------------------------------------
 locator_finalize=0 sparse_finalize=0 windowed_finalize=0 legacy_finalize=1 metadata_complete=1
(1 row)

DROP FUNCTION fb_wal_payload_metadata_contract_debug();
